# 🐛 Отладка: вывод путей в консоль при запуске (только для DEBUG)
# =============================================================================
if DEBUG:
    print("\n" + "="*60)
    print("🔍 GeoDjango: проверка путей к библиотекам")
    print(f"✓ GDAL_LIBRARY_PATH: {GDAL_LIBRARY_PATH}")
    print(f"✓ GEOS_LIBRARY_PATH: {GEOS_LIBRARY_PATH}")
    print(f"✓ PROJ_LIBRARY_PATH: {PROJ_LIBRARY_PATH}")
    print(f"✓ PROJ_LIB: {PROJ_LIB}")
    print(f"✓ GDAL_DATA: {GDAL_DATA}")
    
    # Проверка существования файлов
    for name, path in [
        ('gdal.dll', GDAL_LIBRARY_PATH),
        ('geos_c.dll', GEOS_LIBRARY_PATH),
        ('proj_9.dll', PROJ_LIBRARY_PATH),
        ('proj.db', os.path.join(PROJ_LIB, 'proj.db')),
    ]:
        exists = "✅" if os.path.exists(path) else "❌ НЕ НАЙДЕН"
        print(f"  {exists} {name}: {path}")
    print("="*60 + "\n")


